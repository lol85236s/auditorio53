# Example environment variables for deployment
# Database (Postgres)
DATABASE_URL=postgres://user:password@host:5432/dbname

# SendGrid (recommended for serverless)
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=No-Reply <no-reply@example.com>

# Resend (recommended alternative)
RESEND_API_KEY=your_resend_api_key

# SMTP fallback (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=smtp-user
SMTP_PASS=smtp-pass
SMTP_FROM="No-Reply <no-reply@example.com>"

# Socket / realtime service (if using external provider)
# e.g. Pusher, Supabase, or your own socket server
SOCKET_SERVICE_URL=https://realtime.example.com

# Any other keys for third-party services
NEXT_PUBLIC_SOME_KEY=
